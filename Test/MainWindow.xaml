<Window x:Class="Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="5">
            <Button Content="Жирный" Click="BoldButton_Click" Margin="0,0,5,0"/>
            <Button Content="Курсив" Click="ItalicButton_Click" Margin="0,0,5,0"/>
            <ComboBox x:Name="FontSizeComboBox" Width="50" SelectionChanged="FontSizeComboBox_SelectionChanged" Margin="0,0,5,0">
                <ComboBoxItem Content="12"/>
                <ComboBoxItem Content="16"/>
                <ComboBoxItem Content="20"/>
            </ComboBox>
            <Button Content="Цвет текста" Click="ColorButton_Click" Margin="0,0,5,0"/>
            <Button Content="Добавить изображение" Click="AddImageButton_Click" Margin="0,0,5,0"/>
            <Button Content="Изменить фон" Click="ChangeBackgroundButton_Click" Margin="0,0,5,0"/>
            <TextBox x:Name="MarginInput" Width="50" Text="20" ToolTip="Отступ от краев" Margin="0,0,5,0"/>
            <Button Content="Применить отступ" Click="ApplyMarginButton_Click" Margin="0,0,5,0"/>
            <ComboBox x:Name="LineSpacingComboBox" Width="60" SelectionChanged="LineSpacingComboBox_SelectionChanged" ToolTip="Интервал между строками">
                <ComboBoxItem Content="1"/>
                <ComboBoxItem Content="2"/>
                <ComboBoxItem Content="5"/>
                <ComboBoxItem Content="10"/>
                <ComboBoxItem Content="20"/>
                <ComboBoxItem Content="30"/>
            </ComboBox>
        </StackPanel>

        <!-- RichTextBox -->
        <RichTextBox x:Name="richTextBox" Grid.Row="1" Margin="5" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
