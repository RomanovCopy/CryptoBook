<Application x:Class="CryptoBook.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:locators="clr-namespace:CryptoBook.Locators"
             xmlns:infra="clr-namespace:CryptoBook.Infrastructure"
             xmlns:local="clr-namespace:CryptoBook">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/WindowStyles.xaml"/>
                <ResourceDictionary Source="Styles/ControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <infra:ResourceWrapper x:Key="Res"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
