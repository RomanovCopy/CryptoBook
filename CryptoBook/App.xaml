<Application x:Class="CryptoBook.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:CryptoBook.Infrastructure"
             xmlns:local="clr-namespace:CryptoBook">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/WindowStyles.xaml"/>
                <ResourceDictionary Source="/Styles/ControlStyles.xaml"/>
                <ResourceDictionary Source="/Styles/ImageStyles.xaml"/>
                <ResourceDictionary Source="/Themes/LightTheme.xaml"/>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/Styles/ListStyles.xaml"/>
                <ResourceDictionary Source="/Styles/ImageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="CurrentWindowBackground" Color="Gray" />
            <SolidColorBrush x:Key="CurrentWindowForeground" Color="Black" />
            <SolidColorBrush x:Key="CurrentTitleBarBackground" Color="Gray" />
            <SolidColorBrush x:Key="CurrentTitleBarForeground" Color="Black" />
            <SolidColorBrush x:Key="CurrentBorderColor" Color="Black" />
            <Thickness x:Key="CurrentMargin">10,2,10,2</Thickness>
            <infra:ResourceWrapper x:Key="Res"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
