<Application x:Class="CryptoBook.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:locators="clr-namespace:CryptoBook.Locators"
             xmlns:infra="clr-namespace:CryptoBook.Infrastructure"
             xmlns:local="clr-namespace:CryptoBook">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/WindowStyles.xaml"/>
                <ResourceDictionary Source="/Styles/ControlStyles.xaml"/>
                <ResourceDictionary Source="/Themes/LightTheme.xaml"/>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="CurrentWindowBackground" Color="LightGray" />
            <SolidColorBrush x:Key="CurrentWindowForeground" Color="LightGray" />
            <SolidColorBrush x:Key="CurrentTitleBarBackground" Color="LightGray" />
            <SolidColorBrush x:Key="CurrentTitleBarForeground" Color="LightGray" />
            <SolidColorBrush x:Key="CurrentBorderColor" Color="LightGray" />
            <infra:ResourceWrapper x:Key="Res"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
