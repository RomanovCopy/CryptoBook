<Page x:Class="CryptoBook.MyPages.TimeWebAIPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:controls="clr-namespace:CryptoBook.MyControls"
      xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
      xmlns:markup="clr-namespace:CryptoBook.Markup"
      xmlns:local="clr-namespace:CryptoBook.MyPages"
      mc:Ignorable="d" 
      d:DataContext="{x:Type interfaces:ITimeWebAIPageViewModel}">
    <Page.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:ITimeWebAIPageViewModel}"/>
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ContentControl Grid.Row="0" Content="{markup:ResolveUserControl UserControlType={x:Type controls:TitleBarTimeWebAIControl}}"/>
        <ContentControl Grid.Row="1" Content="{markup:ResolveUserControl UserControlType={x:Type controls:TimeWebAIControl}}"/>
    </Grid>
</Page>
