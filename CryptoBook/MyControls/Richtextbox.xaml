<UserControl x:Class="CryptoBook.MyControls.Richtextbox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:markup="clr-namespace:CryptoBook.Markup"
             xmlns:infra="clr-namespace:CryptoBook.Infrastructure"
             xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
             xmlns:viewmodels="clr-namespace:CryptoBook.ViewModels"
             xmlns:local="clr-namespace:CryptoBook.MyControls" xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DataContext="{x:Type viewmodels:RichtextboxViewModel}">
    <UserControl.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:IRichtextboxViewModel}"/>
    </UserControl.DataContext>
    <infra:BindableRichtextbox DocumentContent="{Binding Document, UpdateSourceTrigger=PropertyChanged}"/>

</UserControl>
