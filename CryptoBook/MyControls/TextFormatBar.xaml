<UserControl x:Class="CryptoBook.MyControls.TextFormatBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:markup="clr-namespace:CryptoBook.Markup"
             xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
             xmlns:local="clr-namespace:CryptoBook.MyControls"
             mc:Ignorable="d" 
             d:DataContext="{markup:ResolveViewModel ViewModelType={x:Type interfaces:ITextFormatBarViewModel}}">
    <UserControl.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:ITextFormatBarViewModel}"/>
    </UserControl.DataContext>
    
    <UserControl.Resources>

        <Style TargetType="Popup">
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="PopupAnimation" Value="Slide"/>
            <Setter Property="StaysOpen" Value="False"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3,0,3,2"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="textBlockHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="BlueViolet"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        </UserControl.Resources>

        <Grid>
            <!-- Кнопка для вызова панели -->
            <ToggleButton x:Name="TogglePanelButton"
                      Style="{StaticResource RoundedToggleButtonStyle}"
                      Content="Text"
                      Height="20"
                      FontWeight="Medium"/>
            <!-- Popup-панель -->
            <Popup PlacementTarget="{Binding ElementName=TogglePanelButton}"
               Placement="Bottom"
               IsOpen="{Binding IsChecked, ElementName=TogglePanelButton}"
               StaysOpen="False">
                <Border Background="Gray"
                    BorderBrush="Black" BorderThickness="1"
                    Padding="5"
                    CornerRadius="5"
                    HorizontalAlignment="Stretch"
                    RenderTransformOrigin="0.5,0">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" >
                        

                        <StackPanel Orientation="Vertical" x:Name="panelAlignLeft">
                            <TextBlock Text="Left" Style="{StaticResource textBlockHeader}"/>
                            <!-- Align Left -->
                            <Button Command="{Binding SetTextAlignment, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Align Left"
                                Template="{StaticResource FlatButtonControlTemplate}">
                                <Image Source="{StaticResource alignleftimage}"/>
                                <Button.CommandParameter>
                                    <TextAlignment>Left</TextAlignment>
                                </Button.CommandParameter>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" x:Name="panelAlignCenter">
                            <TextBlock Text="Center" Style="{StaticResource textBlockHeader}"/>
                            <!-- Align Center -->
                            <Button Command="{Binding SetTextAlignment, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Align Center"
                                Template="{StaticResource FlatButtonControlTemplate}">
                                <Image Source="{StaticResource aligncenterimage}"/>
                                <Button.CommandParameter>
                                    <TextAlignment>Center</TextAlignment>
                                </Button.CommandParameter>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" x:Name="panelAlignRight">
                            <TextBlock Text="Right" Style="{StaticResource textBlockHeader}"/>
                            <!-- Align Right -->
                            <Button Command="{Binding SetTextAlignment, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Align Right"
                                Template="{StaticResource FlatButtonControlTemplate}">
                                <Image Source="{StaticResource alignrightimage}"/>
                                <Button.CommandParameter>
                                    <TextAlignment>Right</TextAlignment>
                                </Button.CommandParameter>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" x:Name="panelImage">
                            <TextBlock Text="Justify" Style="{StaticResource textBlockHeader}"/>
                            <Button Command="{Binding SetTextAlignment, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Align Justify"
                                Template="{StaticResource FlatButtonControlTemplate}">
                                <Image Source="{StaticResource alignjustifyimage}"/>
                                <Button.CommandParameter>
                                    <TextAlignment>Justify</TextAlignment>
                                </Button.CommandParameter>
                            </Button>
                        </StackPanel>

                    <StackPanel Orientation="Vertical" x:Name="panelNewParagraph">
                        <TextBlock Text="New Paragraph" Style="{StaticResource textBlockHeader}"/>
                        <Button Command="{Binding SetParagraphIndent, UpdateSourceTrigger=PropertyChanged}"
                                CommandParameter="20"
                                ToolTip="New Paragraph"
                                Template="{StaticResource FlatButtonControlTemplate}">
                            <Image Source="{StaticResource newParagraph}"/>
                        </Button>
                    </StackPanel>

                </StackPanel>
                </Border>
            </Popup>

        </Grid>
</UserControl>
