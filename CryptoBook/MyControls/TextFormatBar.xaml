<UserControl x:Class="CryptoBook.MyControls.TextFormatBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:markup="clr-namespace:CryptoBook.Markup"
             xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
             xmlns:local="clr-namespace:CryptoBook.MyControls"
             mc:Ignorable="d" 
             d:DataContext="{markup:ResolveViewModel ViewModelType={x:Type interfaces:ITextFormatBarViewModel}}">
    <UserControl.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:ITextFormatBarViewModel}"/>
    </UserControl.DataContext>
    
    <UserControl.Resources>

        <Style TargetType="Popup">
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="PopupAnimation" Value="Slide"/>
            <Setter Property="StaysOpen" Value="False"/>
        </Style>
        <!--<Style TargetType="Button">
            <Setter Property="Margin" Value="3,0,3,2"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>-->
        <Style x:Key="textBlockHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="BlueViolet"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        </UserControl.Resources>

        <Grid>
            <!-- Кнопка для вызова панели -->
            <ToggleButton x:Name="TogglePanelButton"
                      Style="{StaticResource RoundedToggleButtonStyle}"
                      Content="Text"
                      Height="20"
                      FontWeight="Medium"/>
            <!-- Popup-панель -->
            <Popup PlacementTarget="{Binding ElementName=TogglePanelButton}"
               Placement="Bottom"
               IsOpen="{Binding IsChecked, ElementName=TogglePanelButton}"
               StaysOpen="False">
                <Border Background="Gray"
                    BorderBrush="Black" BorderThickness="1"
                    Padding="5"
                    CornerRadius="5"
                    HorizontalAlignment="Stretch"
                    RenderTransformOrigin="0.5,0">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" >
                            <!-- Align Left -->
                            <Button Command="{Binding SetTextAlignment, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Align Left" 
                                Template="{StaticResource FlatButtonControlTemplate}">
                                <Button.CommandParameter>
                                    <TextAlignment>Left</TextAlignment>
                                </Button.CommandParameter>
                                <Canvas Width="24" Height="24">
                                    <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="3" Margin="0"/>
                                    <Rectangle Width="14" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="7" Margin="0"/>
                                    <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="11" Margin="0"/>
                                    <Rectangle Width="14" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="15" Margin="0"/>
                                    <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="19" Margin="0"/>
                                </Canvas>
                        </Button>
                            <!-- Align Center -->
                            <Button Command="{Binding SetTextAlignment, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Align Center"
                                Template="{StaticResource FlatButtonControlTemplate}">
                                <Button.CommandParameter>
                                    <TextAlignment>Center</TextAlignment>
                                </Button.CommandParameter>
                            <Canvas Width="24" Height="24">
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="3" Margin="0"/>
                                <Rectangle Width="14" Height="1" Fill="Black"
                   Canvas.Left="5" Canvas.Top="7" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="11" Margin="0"/>
                                <Rectangle Width="14" Height="1" Fill="Black"
                   Canvas.Left="5" Canvas.Top="15" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="19" Margin="0"/>
                            </Canvas>
                        </Button>
                            <!-- Align Right -->
                            <Button Command="{Binding SetTextAlignment, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Align Right"
                                Template="{StaticResource FlatButtonControlTemplate}">
                                <Button.CommandParameter>
                                    <TextAlignment>Right</TextAlignment>
                                </Button.CommandParameter>
                            <Canvas Width="24" Height="24">
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="3" Margin="0"/>
                                <Rectangle Width="14" Height="1" Fill="Black"
                   Canvas.Left="8" Canvas.Top="7" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="11" Margin="0"/>
                                <Rectangle Width="14" Height="1" Fill="Black"
                   Canvas.Left="8" Canvas.Top="15" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="19" Margin="0"/>
                            </Canvas>
                        </Button>
                    <!-- Align Justify -->
                    <Button Command="{Binding SetTextAlignment, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Align Justify"
                                Template="{StaticResource FlatButtonControlTemplate}">
                                <Button.CommandParameter>
                                    <TextAlignment>Justify</TextAlignment>
                                </Button.CommandParameter>
                            <Canvas Width="24" Height="24">
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="3" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="7" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="11" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="15" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="19" Margin="0"/>
                            </Canvas>
                        </Button>
                    <!-- New Paragraph -->
                    <Button Command="{Binding SetParagraphIndent, UpdateSourceTrigger=PropertyChanged}"
                                CommandParameter="20" 
                                ToolTip="New Paragraph"
                                Template="{StaticResource FlatButtonControlTemplate}">
                            <Canvas Width="24" Height="24">
                                <Rectangle Width="16" Height="1" Fill="Black"
                   Canvas.Left="6" Canvas.Top="3" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="7" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="11" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="15" Margin="0"/>
                                <Rectangle Width="22" Height="1" Fill="Black"
                   Canvas.Left="1" Canvas.Top="19" Margin="0"/>
                            </Canvas>
                        </Button>
                </StackPanel>
                </Border>
            </Popup>

        </Grid>
</UserControl>
