<UserControl x:Class="CryptoBook.MyControls.FontFormatBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
             xmlns:markup="clr-namespace:CryptoBook.Markup"
             xmlns:local="clr-namespace:CryptoBook.MyControls"
             xmlns:viewmodels="clr-namespace:CryptoBook.ViewModels"
             xmlns:converters="clr-namespace:CryptoBook.Converters"
             mc:Ignorable="d" 
             d:DataContext="{markup:ResolveViewModel ViewModelType={x:Type viewmodels:FontFormatBar_ViewModel}}">
    <UserControl.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:IFontFormatBar_ViewModel}"/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <Style TargetType="Popup">
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="PopupAnimation" Value="Slide"/>
            <Setter Property="StaysOpen" Value="False"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="comboBoxStyle" TargetType="ComboBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Standard"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        </Style>

        <DataTemplate x:Key="SelectedColorTemplate">
            <Rectangle Width="16" Height="16"
                Fill="{Binding Converter={markup:ResolveConverter 
                ConverterType={x:Type converters:ColorToColorConverter}}}" 
                Stroke="Red" StrokeThickness="1" Margin="0,0,10,0" />
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <!-- Кнопка для вызова панели -->
        <ToggleButton x:Name="TogglePanelButton"
                      Content="≡"
                      Height="20"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top"
                      FontWeight="Bold"/>
        <!-- Popup-панель -->
        <Popup PlacementTarget="{Binding ElementName=TogglePanelButton}"
               Placement="Bottom"
               IsOpen="{Binding IsChecked, ElementName=TogglePanelButton}"
               StaysOpen="False">
            <Border Background="#EEEEEE"
                    BorderBrush="Gray" BorderThickness="1"
                    Padding="10"
                    CornerRadius="4"
                    HorizontalAlignment="Stretch"
                    RenderTransformOrigin="0.5,0">


                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" >

                    <ComboBox x:Name="family" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding FontFamilyes}"
                              SelectedItem="{Binding FontFamily, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              ToolTip="Font Family">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding Path=., UpdateSourceTrigger=PropertyChanged}" 
                                            FontFamily="{Binding Path=., UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction 
                                    Command="{Binding SetFontFamilyCommand, UpdateSourceTrigger=PropertyChanged}"
                                    CommandParameter=
                                    "{Binding SelectedItem,RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>

                    <ComboBox x:Name="style" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding FontStyles}"
                              SelectedItem="{Binding FontStyle, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              ToolTip="Font Style">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction 
                                    Command="{Binding SetFontStyleCommand, UpdateSourceTrigger=PropertyChanged}"
                                    CommandParameter=
                                    "{Binding SelectedItem,RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>

                    <ComboBox x:Name="weight" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding FontWeights}"
                              SelectedItem="{Binding FontWeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="Font Weight">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction 
                                    Command="{Binding SetFontWeightCommand, UpdateSourceTrigger=PropertyChanged}"
                                    CommandParameter=
                                    "{Binding SelectedItem,RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>

                    <ComboBox x:Name="decoration" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding TextDecorations}"
                              SelectedItem="{Binding TextDecoration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="Text Decoration">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <ContentControl >
                                    <TextBlock Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged}" TextDecorations="{Binding Path=Decorations}"/>
                                </ContentControl>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction 
                                    Command="{Binding SetTextDecorationCommand, UpdateSourceTrigger=PropertyChanged}"
                                    CommandParameter=
                                    "{Binding SelectedItem,RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>

                    <!-- FontSize -->
                    <ComboBox x:Name="fontsize" Style="{StaticResource comboBoxStyle}"
                              ToolTip="Font Size"
                              ItemsSource="{Binding FontSizes}"
                              SelectedItem="{Binding FontSize, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding SetFontSizeCommand,
                                    UpdateSourceTrigger=PropertyChanged}" 
                                    CommandParameter="{Binding SelectedItem, 
                                    RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>

                    <!-- FontColor -->
                    <ComboBox ItemsSource="{Binding FontColors}" 
                              SelectedItem="{Binding FontColor, Mode=TwoWay}" Width="100" Height="24">

                        <!-- Вид каждого элемента -->
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="16" Height="16" Margin="2"
                                        Fill="{Binding Converter={markup:ResolveConverter 
                                        ConverterType={x:Type converters:ColorToColorConverter}}}" 
                                        Stroke="Black" StrokeThickness="1"/>
                                    <TextBlock Text="{Binding}" Margin="4,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>

                        <!-- Переопределяем ControlTemplate для отображения выбранного цвета -->
                        <ComboBox.Template>
                            <ControlTemplate TargetType="ComboBox">
                                <Grid>
                                    <ToggleButton x:Name="ToggleButton" Focusable="false"
                                        IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, 
                                        RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                        <ContentPresenter x:Name="ContentSite"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                            Content="{TemplateBinding SelectionBoxItem}" />
                                    </ToggleButton>
                                    <ContentPresenter x:Name="SelectedColorRectangle"
                                        Content="{TemplateBinding SelectedItem}"
                                        ContentTemplate="{StaticResource SelectedColorTemplate}"
                                        VerticalAlignment="Center"  Margin="4,0,25,0"/>
                                    <Popup x:Name="Popup" Placement="Bottom"
                                        IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"
                                        Focusable="False" PopupAnimation="Slide">
                                        <Grid MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            MinWidth="{TemplateBinding ActualWidth}">
                                            <Border BorderThickness="1" Background="White" BorderBrush="Gray">
                                                <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                                    <StackPanel IsItemsHost="True" />
                                                </ScrollViewer>
                                            </Border>
                                        </Grid>
                                    </Popup>
                                </Grid>
                            </ControlTemplate>
                        </ComboBox.Template>
                        <!-- Привязка команды -->
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction 
                                    Command="{Binding SetFontColorCommand,UpdateSourceTrigger=PropertyChanged}" 
                                    CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>


                    <!-- Align Left -->
                    <Button ToolTip="Align Left"
                    Content="&#xE8E4;"
                    Command="{Binding AlignLeftCommand}"/>

                    <!-- Align Center -->
                    <Button ToolTip="Align Center"
                    Content="&#xE8E3;"
                    Command="{Binding AlignCenterCommand}"/>

                    <!-- Align Right -->
                    <Button ToolTip="Align Right"
                    Content="&#xE8E2;"
                    Command="{Binding AlignRightCommand}"/>

                    <!-- Insert Image -->
                    <Button ToolTip="Insert Image"
                    Content="&#xE722;"
                    Command="{Binding InsertImageCommand}"/>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</UserControl>
