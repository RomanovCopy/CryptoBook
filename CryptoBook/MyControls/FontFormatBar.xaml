<UserControl x:Class="CryptoBook.MyControls.FontFormatBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
             xmlns:markup="clr-namespace:CryptoBook.Markup"
             xmlns:local="clr-namespace:CryptoBook.MyControls"
             xmlns:viewmodels="clr-namespace:CryptoBook.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{markup:ResolveViewModel ViewModelType={x:Type interfaces:IFontFormatBar_ViewModel}}">
    <UserControl.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:IFontFormatBar_ViewModel}"/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <Style TargetType="Popup">
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="PopupAnimation" Value="Slide"/>
            <Setter Property="StaysOpen" Value="False"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <!-- Стиль для ComboBox -->
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Кнопка для вызова панели -->
        <ToggleButton x:Name="TogglePanelButton"
                      Content="≡"
                      Height="20"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top"
                      FontWeight="Bold"/>
        <!-- Popup-панель -->
        <Popup PlacementTarget="{Binding ElementName=TogglePanelButton}"
               Placement="Bottom"
               IsOpen="{Binding IsChecked, ElementName=TogglePanelButton}"
               StaysOpen="False">
            <Border Background="#EEEEEE"
                    BorderBrush="Gray" BorderThickness="1"
                    Padding="10"
                    CornerRadius="4"
                    HorizontalAlignment="Stretch"
                    RenderTransformOrigin="0.5,0">


                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" >

                    <!-- Bold -->
                    <Button ToolTip="Bold"
                    Content="&#xE8DD;"
                    Command="{Binding BoldCommand, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Italic -->
                    <Button ToolTip="Italic"
                    Content="&#xE8DB;"
                    Command="{Binding ItalicCommand,UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Underline -->
                    <Button ToolTip="Underline"
                    Content="&#xE8DC;"
                    Command="{Binding UnderlineCommand, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- FontFamily -->
                    <ComboBox Style="{StaticResource ComboBoxStyle}"
                    ToolTip="Font Family"
                    ItemsSource="{Binding FontFamilies}"
                    SelectedItem="{Binding SelectedFontFamily, Mode=TwoWay}"/>

                    <!-- FontSize -->
                    <ComboBox Style="{StaticResource ComboBoxStyle}"
                    ToolTip="Font Size"
                    ItemsSource="{Binding FontSizes}"
                    SelectedIndex="0"
                    SelectedItem="{Binding FontSize, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding FontSizeCommand, 
                                    UpdateSourceTrigger=PropertyChanged}" 
                                    CommandParameter="{Binding SelectedItem, 
                                    RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>

                    <!-- Align Left -->
                    <Button ToolTip="Align Left"
                    Content="&#xE8E4;"
                    Command="{Binding AlignLeftCommand}"/>

                    <!-- Align Center -->
                    <Button ToolTip="Align Center"
                    Content="&#xE8E3;"
                    Command="{Binding AlignCenterCommand}"/>

                    <!-- Align Right -->
                    <Button ToolTip="Align Right"
                    Content="&#xE8E2;"
                    Command="{Binding AlignRightCommand}"/>

                    <!-- Insert Image -->
                    <Button ToolTip="Insert Image"
                    Content="&#xE722;"
                    Command="{Binding InsertImageCommand}"/>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</UserControl>
