<UserControl x:Class="CryptoBook.MyControls.ListFormatBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:viewmodels="clr-namespace:CryptoBook.ViewModels"
             xmlns:markup="clr-namespace:CryptoBook.Markup"
             xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
             xmlns:local="clr-namespace:CryptoBook.MyControls"
             mc:Ignorable="d"
             d:DataContext="{markup:ResolveViewModel ViewModelType={x:Type interfaces:IListFormatBarViewModel}}">
    <UserControl.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:IListFormatBarViewModel}"/>
    </UserControl.DataContext>
    <Grid>
        <!-- Кнопка для вызова панели -->
        <ToggleButton x:Name="TogglePanelButton"
                      Style="{StaticResource RoundedToggleButtonStyle}"
                      Content="List"
                      Height="20"
                      FontWeight="Medium"/>
        <!-- Popup-панель -->
        <Popup PlacementTarget="{Binding ElementName=TogglePanelButton}"
                Placement="Bottom"
                IsOpen="{Binding IsChecked, ElementName=TogglePanelButton}"
                AllowsTransparency="True"
                PopupAnimation="Slide"
                StaysOpen="False">
            <Border Background="Gray"
                    BorderBrush="Black" BorderThickness="1"
                    Padding="5"
                    CornerRadius="5"
                    HorizontalAlignment="Stretch"
                    RenderTransformOrigin="0.5,0">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" >
                    <!-- ToggleBulleted -->
                    <Button Command="{Binding ToggleBulleted, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Bullet List" Content="{StaticResource Icon_BulletList}"
                                Template="{StaticResource FlatButtonControlTemplate}"> 
                    </Button>
                    <!-- ToggleNumbered -->
                    <Button Command="{Binding ToggleNumbered, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Numbered List" Content="{StaticResource Icon_NumberedList}"
                                Template="{StaticResource FlatButtonControlTemplate}">
                    </Button>
                    <!-- ClearLists -->
                    <Button Command="{Binding ClearLists, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Clear Lists" Content="{StaticResource Icon_ClearList}"
                                Template="{StaticResource FlatButtonControlTemplate}">
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
