<UserControl x:Class="CryptoBook.MyControls.SideMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:convert="clr-namespace:CryptoBook.Converters"
             xmlns:markup="clr-namespace:CryptoBook.Markup"
             xmlns:local="clr-namespace:CryptoBook.MyControls"
             BorderBrush="{DynamicResource CurrentBorderColor}"
             BorderThickness="1,0,1,0"
             mc:Ignorable="d">
    <UserControl.Width>
        <Binding Path="Width" Converter="{markup:ResolveConverter ConverterType={x:Type convert:InternalSizeConverter}}" 
         ConverterParameter="width" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
    </UserControl.Width>

    <Grid Background="Transparent" HorizontalAlignment="Stretch" >
        <TreeView ItemsSource="{Binding MenuItems, UpdateSourceTrigger=PropertyChanged}"
                  Background="Transparent"
                  BorderThickness="0">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children, UpdateSourceTrigger=PropertyChanged}">
                    <ContentPresenter />
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <StaticResource ResourceKey="TreeViewItemStyle"/>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </Grid>
</UserControl>
