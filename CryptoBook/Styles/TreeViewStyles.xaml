<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
                    xmlns:system="clr-namespace:System;assembly=System.Runtime"
                    xmlns:markup="clr-namespace:CryptoBook.Markup"
                    xmlns:converters="clr-namespace:CryptoBook.Converters">

  <!--#region  FILE EXPLORER -->
    
    

    <!-- =========================================================
         БАЗОВЫЕ РЕСУРСЫ (цвета/размеры) — можно привязать к вашей теме
         ========================================================= -->
    <Thickness x:Key="Tv_Padding">6,4,6,4</Thickness>
    <Thickness x:Key="Tv_ItemPadding">6,3,6,3</Thickness>
    <CornerRadius x:Key="Tv_ItemCorner">6</CornerRadius>

    <SolidColorBrush x:Key="Tv_Bg" Color="#00000000"/>
    <SolidColorBrush x:Key="Tv_Fg" Color="#EAEAEA"/>

    <SolidColorBrush x:Key="Tv_RowHover" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="Tv_RowSelected" Color="#335AA9FF"/>
    <SolidColorBrush x:Key="Tv_RowSelectedInactive" Color="#223B82D9"/>
    <SolidColorBrush x:Key="Tv_BorderFocus" Color="#5AA9FF"/>

    <SolidColorBrush x:Key="Tv_ExpanderFg" Color="#BFBFBF"/>

    <system:Double x:Key="Tv_Indent">16</system:Double>
    <system:Double x:Key="Tv_IconSize">16</system:Double>

    <!-- =========================================================
         Expander (стрелка)
         ========================================================= -->
    <Style x:Key="DiskTree_ExpanderToggleStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <!-- стрелка -->
                        <Path x:Name="Arrow"
                              Fill="{StaticResource Tv_ExpanderFg}"
                              Data="M 0 0 L 0 8 L 6 4 Z"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Path.RenderTransform>
                        </Path>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Arrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Arrow" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Arrow" Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         TreeViewItem — строка целиком кликабельна, hover/selected,
         нормальная индикация фокуса, виртуализация
         ========================================================= -->
    <Style x:Key="DiskTree_TreeViewItemStyle" TargetType="{x:Type TreeViewItem}">
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        <Setter Property="Foreground" Value="{StaticResource Tv_Fg}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Continue"/>
        <Setter Property="KeyboardNavigation.TabNavigation" Value="None"/>
        <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TreeViewItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Expander -->
                        <ToggleButton x:Name="Expander"
                                      Grid.Column="0"
                                      Margin="2,0,2,0"
                                      Style="{StaticResource DiskTree_ExpanderToggleStyle}"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      Visibility="Visible"/>

                        <!-- Row -->
                        <Border x:Name="Row"
                                Grid.Column="1"
                                Padding="{StaticResource Tv_ItemPadding}"
                                CornerRadius="{StaticResource Tv_ItemCorner}"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <ContentPresenter x:Name="HeaderHost"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <!-- Children -->
                        <ItemsPresenter x:Name="ItemsHost"
                                        Grid.Column="1"
                                        Margin="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Level, Converter={x:Null}}"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- если нет дочерних — скрыть expander -->
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                        </Trigger>

                        <!-- hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{StaticResource Tv_RowHover}"/>
                        </Trigger>

                        <!-- selected -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{StaticResource Tv_RowSelected}"/>
                        </Trigger>

                        <!-- selected, но фокус в другом месте -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Row" Property="Background" Value="{StaticResource Tv_RowSelectedInactive}"/>
                        </MultiTrigger>

                        <!-- фокус рамкой -->
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Row" Property="BorderBrush" Value="{StaticResource Tv_BorderFocus}"/>
                        </Trigger>

                        <!-- раскрытие -->
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <!-- отключено -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         TreeView — строгий стиль (ключом), удобство:
         Virtualization, ScrollViewer, навигация клавиатурой
         ========================================================= -->
    <Style x:Key="DiskTree_TreeViewStyle" TargetType="{x:Type TreeView}">
        <Setter Property="Background" Value="{StaticResource Tv_Bg}"/>
        <Setter Property="Foreground" Value="{StaticResource Tv_Fg}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="{StaticResource Tv_Padding}"/>

        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>

        <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>

        <Setter Property="ItemContainerStyle" Value="{StaticResource DiskTree_TreeViewItemStyle}"/>

        <!-- Чтобы заголовок был кликабелен по всей ширине -->
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

        <!-- легкий контроль Tab -->
        <Setter Property="KeyboardNavigation.TabNavigation" Value="Once"/>

        <!-- общий шаблон TreeView -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TreeView}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer Focusable="False"
                                      HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                      VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                      CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         ШАБЛОНЫ ДАННЫХ (пример): диск / каталог / файл
         Иконка как ImageSource в VM (Icon)
         ========================================================= -->
    <DataTemplate x:Key="DiskTree_DriveTemplate">

        <StackPanel Orientation="Horizontal" Margin="2">
            <!-- Иконка диска (можно улучшить с Image) -->
            <TextBlock Text="💾" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>

            <StackPanel>
                <TextBlock FontWeight="Bold">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} [{1}]">
                            <Binding Path="RootDirectory"/>
                            <Binding Path="VolumeLabel"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <TextBlock FontSize="11" Foreground="Gray">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} • Свободно: {1:F1} ГБ из {2:F1} ГБ">
                            <Binding Path="DriveFormat"/>
                            <Binding Path="AvailableFreeSpace" Converter="{markup:ResolveConverter ConverterType={x:Type converters:BytesToGbConverter}}"/>
                            <Binding Path="TotalSize" Converter="{markup:ResolveConverter ConverterType={x:Type converters:BytesToGbConverter}}"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </StackPanel>


        <!--<DockPanel LastChildFill="True">
            <Image Width="{StaticResource Tv_IconSize}"
                   Height="{StaticResource Tv_IconSize}"
                   Margin="0,0,6,0"
                   Source="{Binding Icon}"/>
            <TextBlock Text="{Binding Name}" />
        </DockPanel>-->
    </DataTemplate>

    <DataTemplate x:Key="DiskTree_DirectoryTemplate">
        <DockPanel LastChildFill="True">
            <Image Width="{StaticResource Tv_IconSize}"
                   Height="{StaticResource Tv_IconSize}"
                   Margin="0,0,6,0"
                   Source="{Binding Icon}"/>
            <TextBlock Text="{Binding Name}" />
        </DockPanel>
    </DataTemplate>

    <DataTemplate x:Key="DiskTree_FileTemplate">
        <DockPanel LastChildFill="True">
            <Image Width="{StaticResource Tv_IconSize}"
                   Height="{StaticResource Tv_IconSize}"
                   Margin="0,0,6,0"
                   Source="{Binding Icon}"/>
            <TextBlock Text="{Binding Name}" />
        </DockPanel>
    </DataTemplate>

 <!--#endregion-->




</ResourceDictionary>