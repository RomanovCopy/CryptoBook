<ResourceDictionary 
    x:Class="CryptoBook.Styles.WindowStyles" 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:markup="clr-namespace:CryptoBook.Markup"
    xmlns:interfaces="clr-namespace:CryptoBook.Interfaces">
    

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ColorStyles.xaml"/>
        <ResourceDictionary Source="ButtonStyles.xaml"/>
        <ResourceDictionary Source="ImageStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>



    <Style x:Key="VS2012WindowStyle" TargetType="{x:Type Window}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ResizeMode" Value="CanResizeWithGrip" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Window}">
                    <Grid
                        Margin="1"
                        TextOptions.TextRenderingMode="ClearType"
                        TextOptions.TextFormattingMode="Display">
                        <Border
                            x:Name="PART_Border"
                            Width="Auto"
                            Height="Auto"
                            Background="{DynamicResource CurrentWindowBackground}"
                            Padding="0">
                            <Border.Effect>
                                <DropShadowEffect
                                    Color="Black"
                                    Opacity="0.5"
                                    BlurRadius="7"
                                    ShadowDepth="2"
                                    Direction="315"/>
                            </Border.Effect>
                            <DockPanel   
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource CurrentWindowBackground}"
                                VerticalAlignment="Stretch" 
                                >
                                <Border
                                    x:Name="TitleBar"
                                    DockPanel.Dock="Top"
                                    Background="{DynamicResource CurrentTitleBarBackground}"
                                    BorderThickness="0"
                                    DataContext="{markup:ResolveViewModel ViewModelType={x:Type interfaces:ITitleBarViewModel}}"
                                    Opacity="0.5"
                                    >
                                    <Grid Height="Auto">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <!--Button Back-->
                                            <ColumnDefinition Width="Auto"/>
                                            <!--Button Forward-->
                                            <ColumnDefinition Width="Auto"/>
                                            <!--Icon-->
                                            <ColumnDefinition Width="Auto"/>
                                            <!--Title-->
                                            <ColumnDefinition Width="Auto"/>
                                            <!--ComboBox-->
                                            <ColumnDefinition Width="*"/>
                                            <!--CurrentPath-->
                                            <ColumnDefinition Width="*"/>
                                            <!--Search-->
                                            <ColumnDefinition Width="24"/>
                                            <!--Button MinSize-->
                                            <ColumnDefinition Width="24"/>
                                            <!--Button MaxSize-->
                                            <ColumnDefinition Width="24"/>
                                            <!--Button Close-->
                                        </Grid.ColumnDefinitions>
                                        <Button
                                            x:Name="buttonBack" 
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Width="18"
                                            Height="18"
                                            Command="{Binding ButtonBack_Click, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource VS2012WindowStyleNavigationButton}">
                                            <Image Source="{StaticResource backimage}"/>
                                        </Button>
                                        <Button
                                            x:Name="buttonForward" 
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Width="18"
                                            Height="18"
                                            Command="{Binding ButtonForward_Click, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource VS2012WindowStyleNavigationButton}">
                                            <Image Source="{StaticResource forwardimage}"/>
                                        </Button>
                                        <Button x:Name="MenuButton"
                                                Grid.Column="2"
                                                Width="24"
                                                Height="24"
                                                Foreground="White"
                                                Style="{StaticResource MenuButtonStyle01}"
                                                Margin="4,0,0,0">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE700;"
                                                       FontSize="16" TextAlignment="Center"/>
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                                    <i:InvokeCommandAction 
                                                        Command="{Binding ToggleMenu_Click,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </Button>
                                        <TextBlock
                                            x:Name="Caption"
                                            Grid.Column="3"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            MinWidth="70"
                                            Margin="4,0,0,0"
                                            FontFamily="Segoe UI"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Opacity="1"
                                            Foreground="White"
                                            Text="{Binding Path=Title, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                        <TextBlock
                                            x:Name="currentpath"
                                            Text="{Binding LastFileName, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="{Binding PathToLastFile, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            MinWidth="150"
                                            Margin="10,4,10,4"
                                            Grid.Column="5"
                                            TextWrapping="NoWrap"
                                            FontWeight="Medium"
                                            Foreground="White"
                                            FontSize="12"
                                            Opacity="1"/>
                                        <Button
                                            x:Name="MinButton" 
                                            Grid.Column="7"
                                            VerticalAlignment="Center"
                                            Width="18"
                                            Height="18"
                                            Style="{StaticResource VS2012WindowStyleTitleBarButton}"
                                            >
                                            <Grid MaxHeight="9" MaxWidth="9">
                                                <Path
                                                    Stroke="{Binding 
                                                    RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                    StrokeThickness="1"
                                                    Stretch="None"
                                                    RenderOptions.EdgeMode="Aliased"
                                                    Data="M0,8 H8 M0,7 H8 M0,6 H8"
                                                    />
                                            </Grid>
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:InvokeCommandAction Command="{Binding        MinButtonClick,UpdateSourceTrigger=PropertyChanged}"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </Button>
                                        <Button
                                            Grid.Column="8"
                                            x:Name="MaxButton" 
                                            VerticalAlignment="Center"
                                            Width="18"
                                            Height="18"
                                            Style="{StaticResource VS2012WindowStyleTitleBarButton}"
                                            >
                                            <Grid MaxHeight="9" MaxWidth="9">
                                                <Path
                                                    x:Name="PART_MaxButton_Path"
                                                    Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                    StrokeThickness="1"
                                                    Stretch="None"
                                                    RenderOptions.EdgeMode="Aliased"
                                                    Data="M0,0 H8 V8 H0 V0 M0,1 H8 M0,2 H8"
                                                    />
                                            </Grid>
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:InvokeCommandAction Command="{Binding        MaxButtonClick,UpdateSourceTrigger=PropertyChanged}"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>

                                        </Button>
                                        <Button
                                            Grid.Column="9"
                                            x:Name="CloseButton" 
                                            VerticalAlignment="Center"
                                            Width="18"
                                            Height="18"
                                            Style="{StaticResource VS2012WindowStyleTitleBarButton}"
                                            >
                                            <Grid MaxHeight="9" MaxWidth="9">
                                                <Path
                                                    Stroke="{Binding 
                                                    RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                    StrokeThickness="1.5"
                                                    Stretch="None"
                                                    Data="M0,0 L8,8 M0,8 L8,0"
                                                    />
                                            </Grid>
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:InvokeCommandAction Command="{Binding        CloseButtonClick,UpdateSourceTrigger=PropertyChanged}"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>

                                        </Button>
                                    </Grid>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="Loaded">
                                            <i:InvokeCommandAction 
                                                Command="{Binding Loaded,
                                                UpdateSourceTrigger=PropertyChanged}"
                                                CommandParameter="{Binding ElementName=TitleBar}"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Border>
                                <ContentPresenter />
                            </DockPanel>
                            <Border.Triggers>
                                <DataTrigger Binding="CurrentTheme">
                                    
                                </DataTrigger>
                            </Border.Triggers>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>