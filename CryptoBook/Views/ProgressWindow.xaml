<Window x:Class="CryptoBook.Views.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:markup="clr-namespace:CryptoBook.Markup"
        xmlns:converters="clr-namespace:CryptoBook.Converters"
        xmlns:local="clr-namespace:CryptoBook.Views"
        mc:Ignorable="d" x:Name="window"
        Title="{Binding OperationName,UpdateSourceTrigger=PropertyChanged}" MinHeight="150" MinWidth="300">

        
        <Window.Width>
            <Binding Path="WindowWidth" Converter="{markup:ResolveConverter ConverterType={x:Type converters:SizeLocationConverter}}" 
             ConverterParameter="width" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
        </Window.Width>
        <Window.Height>
        <Binding Path="WindowHeight" Converter="{markup:ResolveConverter ConverterType={x:Type converters:SizeLocationConverter}}" 
             ConverterParameter="height" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
        </Window.Height>
        <Window.Top>
        <Binding Path="WindowTop" Converter="{markup:ResolveConverter ConverterType={x:Type converters:SizeLocationConverter}}" 
             ConverterParameter="top" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
        </Window.Top>
        <Window.Left>
        <Binding Path="WindowLeft" Converter="{markup:ResolveConverter ConverterType={x:Type converters:SizeLocationConverter}}" 
             ConverterParameter="left" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
        </Window.Left>
    
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- Прогрессбар -->
        <ProgressBar x:Name="pbar" Grid.Row="0" Height="30" Minimum="0" Maximum="100" Value="{Binding Progress, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Текст прогресса -->
        <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" 
                   Text="{Binding ElementName=pbar, Path=Value, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Margin="10"/>

        <!-- Статус -->
        <TextBlock Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Text="{Binding StatusMessage, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Margin="10" Foreground="Red"/>

        <!-- Кнопка отмены -->
        <Button Grid.Row="3" Content="Cancel" Width="80" Height="30" HorizontalAlignment="Center"
                Command="{Binding Canceled, UpdateSourceTrigger=PropertyChanged}" />
    </Grid>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding Loaded, UpdateSourceTrigger=PropertyChanged}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding Closing, UpdateSourceTrigger=PropertyChanged}"/>
        </i:EventTrigger>
        <i:EventTrigger EventName="Closed">
            <i:InvokeCommandAction Command="{Binding Closed, UpdateSourceTrigger=PropertyChanged}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
</Window>
