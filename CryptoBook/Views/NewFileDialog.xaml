<Window x:Class="CryptoBook.Views.NewFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:viewmodels="clr-namespace:CryptoBook.ViewModels"
        xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
        xmlns:markup="clr-namespace:CryptoBook.Markup"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CryptoBook.Views"
        mc:Ignorable="d" Background="{StaticResource CurrentWindowBackground}"
        d:DataContext="{x:Type interfaces:INewFileDialogViewModel}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight" MinWidth="520" MinHeight="300"
        Title="New File" >
    <Window.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:INewFileDialogViewModel}"/>
    </Window.DataContext>
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}"></Style>
        <Style TargetType="TextBlock" >
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16"  >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Директория -->
        <TextBlock Text="Папка:" VerticalAlignment="Center" Grid.Column="0" Grid.Row="0"/>
        <TextBlock Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}" 
                   MinWidth="360" VerticalAlignment="Center" Margin="15,0,15,0" 
                   TextAlignment="Center" Grid.Column="1" Grid.Row="0"/>
        <Button Content="Обзор…" HorizontalAlignment="Stretch" Margin="8,0,0,0" 
                Command="{Binding Browse,UpdateSourceTrigger=PropertyChanged}" 
                        Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="0"/>

        <!-- Только для чтения -->
        <TextBlock Grid.Row="1" Text="Только для чтения:" VerticalAlignment="Center"/>
        <CheckBox Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0"
              IsChecked="{Binding IsReadOnly, UpdateSourceTrigger=PropertyChanged}"/>
        <!-- Скрытый -->
        <TextBlock Grid.Row="2" Text="Скрытый файл:" VerticalAlignment="Center"/>
        <CheckBox Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0"
              IsChecked="{Binding IsHidden, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Тип файла -->
        <TextBlock Grid.Row="3" Text="Тип файла:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="3" Grid.Column="1" Margin="15,0,15,0" VerticalAlignment="Center"
              ItemsSource="{Binding Templates, UpdateSourceTrigger=PropertyChanged}"
              DisplayMemberPath="DisplayName" Grid.ColumnSpan="3"
              SelectedItem="{Binding SelectedTemplate, UpdateSourceTrigger=PropertyChanged}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="SelectionChanged">
                    <i:InvokeCommandAction Command="{Binding SelectedNewTemplate, UpdateSourceTrigger=PropertyChanged}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </ComboBox>

        <!-- Имя файла -->
        <TextBlock Grid.Row="4" Text="Имя файла:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Margin="15,0,15,0" 
                 Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}"  VerticalAlignment="Center"/>

        <!--Расширение файла-->

        <TextBlock Grid.Row="5" Text="Расширение файла:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="5" Grid.Column="1" 
                   Text="{Binding SelectedTemplate.DefaultExtension,Mode=OneWay}" VerticalAlignment="Center"
                   Margin="15,0,0,0"/>

        <!-- Ошибка -->
        <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Foreground="Tomato" TextWrapping="Wrap"
               Text="{Binding ErrorMessage, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" />

        <!-- Кнопки -->
        <StackPanel Grid.Row="7" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" >
            <Button Content="ОК" IsDefault="True" Margin="15,0,15,0"
              Command="{Binding Create, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Отмена" IsCancel="True" Margin="0,0,15,0"
                    Command="{Binding Cancel, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

    </Grid>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding Closing, UpdateSourceTrigger=PropertyChanged}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

</Window>
