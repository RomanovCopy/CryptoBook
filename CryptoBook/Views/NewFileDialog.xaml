<Window x:Class="CryptoBook.Views.NewFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:viewmodels="clr-namespace:CryptoBook.ViewModels"
        xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
        xmlns:markup="clr-namespace:CryptoBook.Markup"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CryptoBook.Views"
        mc:Ignorable="d"
        d:DataContext="{x:Type interfaces:INewFileDialogViewModel}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight" MinWidth="520" MinHeight="300"
        Title="New File" >
    <Window.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:INewFileDialogViewModel}"/>
    </Window.DataContext>
    <Grid Margin="16"  >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Директория -->
        <TextBlock Text="Папка:" VerticalAlignment="Center"/>
        <DockPanel Grid.Column="1" Margin="8,0,0,8">
            <TextBox x:Name="directory" Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}" MinWidth="360" />
            <Button Content="Обзор…" Margin="8,0,0,0" Command="{Binding Browse,UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <!-- Создать при отсутствии -->
        <CheckBox Grid.Row="1" Grid.Column="1" Margin="8,0,0,8"
              Content="Создать папку, если её нет"
              IsChecked="{Binding CreateDirectoryIfMissing, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Только для чтения -->
        <CheckBox Grid.Row="2" Content="Только для чтения" VerticalAlignment="Center"
              IsChecked="{Binding IsReadOnly, UpdateSourceTrigger=PropertyChanged}"/>
        <!-- Скрытый -->
        <CheckBox Grid.Row="3" Content="Скрытый" VerticalAlignment="Center"
              IsChecked="{Binding IsHidden, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Тип файла -->
        <TextBlock Grid.Row="4" Text="Тип файла:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1" Margin="8,0,0,8" VerticalAlignment="Center"
              ItemsSource="{Binding Templates, UpdateSourceTrigger=PropertyChanged}"
              DisplayMemberPath="DisplayName"
              SelectedItem="{Binding SelectedTemplate, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Имя файла -->
        <TextBlock Grid.Row="5" Text="Имя файла:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="5" Grid.Column="1" Margin="8,0,0,8" Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}"  VerticalAlignment="Center"/>
        
        <!--Расширение файла-->

        <TextBlock Grid.Row="6" Text="Расширение файла:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedTemplate.DefaultExtension,Mode=OneWay}" VerticalAlignment="Center"/>

        <!-- Ошибка -->
        <TextBlock Grid.Row="7" Grid.ColumnSpan="2" Foreground="Tomato" TextWrapping="Wrap"
               Text="{Binding ErrorMessage, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" />

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="ОК" IsDefault="True" Margin="0,0,8,0"
              Command="{Binding Create, UpdateSourceTrigger=PropertyChanged}" CommandParameter="{Binding ElementName=directory,Path=Text, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Отмена" IsCancel="True"/>
        </StackPanel>


    </Grid>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding Closing, UpdateSourceTrigger=PropertyChanged}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

</Window>
