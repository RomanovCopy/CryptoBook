<Window x:Class="CryptoBook.Views.NewFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:viewmodels="clr-namespace:CryptoBook.ViewModels"
        xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
        xmlns:markup="clr-namespace:CryptoBook.Markup"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CryptoBook.Views"
        mc:Ignorable="d"
        d:DataContext="{x:Type interfaces:INewFileDialogViewModel}"
        Title="NewFileDialog" Height="450" Width="800">
    <Window.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:INewFileDialogViewModel}"/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="File type:"/>
        <ComboBox Grid.Row="0" Margin="100,0,0,0"
            ItemsSource="{Binding Templates,UpdateSourceTrigger=PropertyChanged}"
            DisplayMemberPath="DisplayName"
            SelectedItem="{Binding SelectedTemplate,UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Text="File name:"/>
        <TextBox Grid.Row="1" Margin="100,0,0,0"
           Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Пример подсказки расширения -->
        <TextBlock x:Name="filename" Grid.Row="2" Margin="0,8,0,0" Opacity="0.7">
      <Run Text="Расширение: "/>
      <Run Text="{Binding SelectedTemplate.DefaultExtension}"/>
        </TextBlock>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Command="{Binding Create,UpdateSourceTrigger=PropertyChanged}" CommandParameter="{Binding ElementName=filename, Path=Text}"/>
            <Button Content="Cancel" Margin="8,0,0,0" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>

</Window>
