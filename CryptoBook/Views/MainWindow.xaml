<Window x:Class="CryptoBook.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="http://schemas.microsoft.com/winfx/2006/xaml/presentation/shell"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:CryptoBook.Behaviors"
        xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
        xmlns:viewmodels="clr-namespace:CryptoBook.ViewModels"
        xmlns:converters="clr-namespace:CryptoBook.Converters"
        xmlns:control="clr-namespace:CryptoBook.MyControls"
        xmlns:markup="clr-namespace:CryptoBook.Markup"
        xmlns:local="clr-namespace:CryptoBook.Views"
        mc:Ignorable="d" WindowStyle="None"
        MinHeight="100" MinWidth="400" Title="CryptoBook"
        HorizontalContentAlignment="Stretch"
        Background="{DynamicResource CurrentWindowBackground}"
        BorderBrush="{DynamicResource CurrentBorderColor}"
        BorderThickness="1,0,1,1"
        d:DataContext="{x:Type viewmodels:MainWindowViewModel}">
    <Window.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:IMainWindowViewModel}"/>
    </Window.DataContext>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Window.Width>
        <Binding Path="WindowWidth" Converter="{markup:ResolveConverter ConverterType={x:Type converters:SizeLocationConverter}}" 
                 ConverterParameter="width" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
    </Window.Width>
    <Window.Height>
        <Binding Path="WindowHeight" Converter="{markup:ResolveConverter ConverterType={x:Type converters:SizeLocationConverter}}" 
                 ConverterParameter="height" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
    </Window.Height>
    <Window.Top>
        <Binding Path="WindowTop" Converter="{markup:ResolveConverter ConverterType={x:Type converters:SizeLocationConverter}}" 
                 ConverterParameter="top" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
    </Window.Top>
    <Window.Left >
        <Binding Path="WindowLeft" Converter="{markup:ResolveConverter ConverterType={x:Type converters:SizeLocationConverter}}" 
                 ConverterParameter="left" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
    </Window.Left>
    <Window.WindowState>
        <Binding Path="WindowState" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
    </Window.WindowState>
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="forTitleBar" Height="Auto"/>
            <RowDefinition x:Name="forMyFrame" Height="*"/>
            <RowDefinition x:Name="forStatusBar" Height="Auto"/>
        </Grid.RowDefinitions>
        <ContentControl Content="{markup:ResolveUserControl UserControlType={x:Type control:TitleBar}}" Grid.Row="0"/>
        <Grid Grid.Row="1" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ContentControl x:Name="sidemenu" Content="{markup:ResolveUserControl UserControlType={x:Type control:SideMenu}}" Grid.Column="0"/>
            <ContentControl Content="{markup:ResolveUserControl UserControlType={x:Type control:MyFrame}}" Grid.Column="1"/>
        </Grid>
    </Grid>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{ Binding Loaded, UpdateSourceTrigger=PropertyChanged}"/>
        </i:EventTrigger>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{ Binding Closing, UpdateSourceTrigger=PropertyChanged}"/>
        </i:EventTrigger>
        <i:EventTrigger EventName="Closed">
            <i:InvokeCommandAction Command="{ Binding Closed, UpdateSourceTrigger=PropertyChanged}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <i:Interaction.Behaviors>
        <behaviors:WindowBehavior 
            SidePanel="{Binding ElementName=sidemenu,UpdateSourceTrigger=PropertyChanged}"
            CloseSidePanelCommand="{Binding SideMenuClose, UpdateSourceTrigger=PropertyChanged}"/>
    </i:Interaction.Behaviors>
</Window>
