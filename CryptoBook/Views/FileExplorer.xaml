<Window x:Class="CryptoBook.Views.FileExplorer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CryptoBook.Views"
        mc:Ignorable="d"
        Title="FileExplorer" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="forNavigetePanel" Height="Auto"/>
            <RowDefinition x:Name="forOperationPanel" Height="Auto"/>
            <RowDefinition x:Name="forListView" Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="forNavigationPane" Width="200"/>
        </Grid.ColumnDefinitions>
        
    </Grid>
</Window>
