<Window x:Class="CryptoBook.Views.FileExplorer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:interfaces="clr-namespace:CryptoBook.Interfaces"
        xmlns:converters="clr-namespace:CryptoBook.Converters"
        xmlns:markup="clr-namespace:CryptoBook.Markup"
        xmlns:icons="System.Drawing.Icon.ExtractAssociatedIcon"
        xmlns:local="clr-namespace:CryptoBook.Views"
        mc:Ignorable="d"
        d:DataContext="{x:Type interfaces:IFileExplorerViewModel}"
        Height="600" Width="1000"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResizeWithGrip"
        Title="FileExplorer">
    <Window.DataContext>
        <markup:ResolveViewModel ViewModelType="{x:Type interfaces:IFileExplorerViewModel}"/>
    </Window.DataContext>

    <Grid Background="{DynamicResource CurrentWindowBackground}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Command Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Address Bar + Tabs -->
            <RowDefinition Height="*"/>
            <!-- Main Content: Nav Pane + File View -->
            <RowDefinition Height="Auto"/>
            <!--Selected File-->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- 1. Command Bar (упрощённая в Win11) -->
        <ToolBar Grid.Row="0" Height="48" Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Button Content="New" Margin="5,0" Padding="10,5"/>
            <Separator/>
            <Button Content="Cut" Margin="5,0" Padding="10,5" Command="{Binding CutCommand, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Copy" Margin="5,0" Padding="10,5" Command="{Binding CopyCommand, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Paste" Margin="5,0" Padding="10,5" Command="{Binding PasteCommand,UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Rename" Margin="5,0" Padding="10,5" Command="{Binding RenameCommand, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Delete" Margin="5,0" Padding="10,5" Command="{Binding DeleteCommand,UpdateSourceTrigger=PropertyChanged}"/>
            <Separator/>
            <Button Content="Sort" Margin="5,0" Padding="10,5"/>
            <Button Content="View" Margin="5,0" Padding="10,5"/>
        </ToolBar>

        <!-- 2. Tabs + Address Bar -->
        <TabControl Grid.Row="1" Margin="0,0,0,5" Background="Transparent" BorderThickness="0">
            <TabItem Header="Home" IsSelected="True">
                <Grid>
                    <TextBox Text="Этот ПК > Диск C: > Users" Margin="10,5" Height="32" 
                             VerticalAlignment="Center" Padding="10,0" FontSize="14"/>
                    <!-- Breadcrumb можно реализовать через ItemsControl -->
                </Grid>
            </TabItem>
            <TabItem Header="Documents"/>
            <TabItem Header="+"/>
            <!-- Кнопка новой вкладки -->
        </TabControl>

        <!-- 3. Основная область: Navigation Pane слева + File View справа -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <!-- Navigation Pane -->
                <ColumnDefinition Width="*"/>
                <!-- File List -->
                <ColumnDefinition Width="250"/>
                <!-- Details Pane (опционально) -->
            </Grid.ColumnDefinitions>

            <!-- Navigation Pane (левая панель) -->
            <TreeView Grid.Column="0" ItemsSource="{Binding GetDirectories,UpdateSourceTrigger=PropertyChanged}"
                      Style="{StaticResource DiskTree_TreeViewStyle}">
                <!-- 1) Для папок/дисков (есть Children) -->
                <HierarchicalDataTemplate DataType="{x:Type vm:FileSystemNode}" ItemsSource="{Binding Children}">
                    <DockPanel LastChildFill="True">
                        <Image Width="{StaticResource Tv_IconSize}"
                       Height="{StaticResource Tv_IconSize}"
                       Margin="0,0,6,0"
                       Source="{Binding Icon}"/>

                        <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                    </DockPanel>

                    <!-- Можно добавить контекстное меню прямо на "строку" -->
                    <HierarchicalDataTemplate.Resources>
                        <Style TargetType="{x:Type DockPanel}">
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Открыть"
                                          Command="{Binding OpenCommand}"/>
                                        <MenuItem Header="Копировать путь"
                                          Command="{Binding CopyPathCommand}"/>
                                        <Separator/>
                                        <MenuItem Header="Переименовать"
                                          Command="{Binding RenameCommand}"/>
                                        <MenuItem Header="Удалить"
                                          Command="{Binding DeleteCommand}"/>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </HierarchicalDataTemplate.Resources>

                    <!-- Ключевой момент: чтобы файлы не пытались “вести” детей,
                 ниже добавим триггер переключающий ItemsSource в null
                 (иначе HasItems будет False и expander будет скрыт, но ItemsSource может быть пустой коллекцией) -->
                    <HierarchicalDataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                            <!-- файл: ItemsSource отключаем -->
                            <Setter Property="ItemsSource" Value="{x:Null}"/>
                        </DataTrigger>
                    </HierarchicalDataTemplate.Triggers>

                </HierarchicalDataTemplate>

            </TreeView>

            <!-- File List View (основная область файлов) -->
            <ListView Grid.Column="1" Background="White">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="300"/>
                        <GridViewColumn Header="Date modified" Width="150"/>
                        <GridViewColumn Header="Type" Width="150"/>
                        <GridViewColumn Header="Size" Width="100"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Details Pane (правая панель деталей) -->
            <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                <StackPanel Margin="10">
                    <TextBlock Text="Details" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Name: Folder1"/>
                    <TextBlock Text="Type: File folder"/>
                    <TextBlock Text="Size: --"/>
                    <Image Source="placeholder.png" Height="200" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>


        </Grid>
        <Border Grid.Row="3" BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="5">
            <TextBox x:Name="selected"  Text="Selected Path" HorizontalAlignment="Stretch"/>
        </Border>

        <!-- 4. Status Bar снизу -->
        <StatusBar Grid.Row="4" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="3">
            <StatusBarItem Content="5 items | 1 selected"/>
        </StatusBar>

    </Grid>
</Window>
