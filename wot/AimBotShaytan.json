{
    "version": "ABS 3.0 #025",
    "autor": "ZorroJan",
    
    "modEnable": true,                      // Вкл.мода по умолчанию

// Клавиши:
// --------
    "toggleKey": "KEY_NUMPAD9",             // Клавиша переключения режимов мода
    "funcKey": "KEY_SPACE",                 // Многофункциональная клавиша
    "pointKey": "KEY_E",                    // Дополнительная клавиша для захвата сектора
    "fixDistKey": "KEY_E",                  // Клавиша фиксации дальномера действует при удержании
    "remModeKey": true,                     // Запомнить выбор клавиши и использовать при каждом захвате
                                            // если false, то клавиша будет применена только к текущему, или первому захвату
                                            // при следующем захвате будет установлен fixPointScrollDefault или AimPoint

// Клавиши быстрого выбора фиксированных точек
    "nldKey": "KEY_NUMPADMINUS",            // НЛД
    "hullKey": "KEY_NUMPADSTAR",            // Корпус
    "turrKey": "KEY_NUMPADSLASH",           // Башня
    "chassisKey": "KEY_ADD",                // Захват шасси
    "fuelKey": "KEY_NUMLOCK",               // Захват топливных баков (клавиша вкл/выкл параметра needFuelTank)

// Клавиши для работы с боевыми режимами
    "modeHardKey": "KEY_F11",               // Клавиша для переключения жёстких режимов
                                            // Default - настройки по конфигу (по умолчанию)
                                            // OneTouch - захват АвтоБотом одной выбранной точки (условие пробитие 85%)
                                            // FastPoint - быстрый поиск лучшего места для пробития
                                            // Chassis - захват ходовой части
                                            // NoPoint - не выбирать точки выцеливания, работать по НЛД, корпус, башня
                                            // сброс на Default funcKey + modeKey

    "modeSoftKey": "KEY_F12",               // Клавиша для переключения параметров в дополнительных настраиваемых режимах

// Параметры:
// ----------
    "RMB_funcEnable": false,                // Добавить ПКМ качество функциональной клавиши
    "captureTimeHalt": 0.28,                // Время задержки срабатывания захвата выбранной точки по удержанию ПКМ, в сек.
    "markerAttack": true,                   // Метить цель маркером атаки, при комбинации ЛКМ или ПКМ + funcKey
    "captureGunClinch": false,              // Захватывать орудие противника во время клинча
                                            // Захват осуществляется во время перезарядки, либо при удержании funcKey
                                            // если false, то при удержании funcKey
    "captureSound": 3,                      // Вариант озвучки захвата: 0 - отключено, 1 - голос, 2 - звук, 3 - совмещённый вариант

// Настройки рентген-захвата
    "captureNext": false,                   // Захватывать ли другую цель сразу, без промежуточного сброса
    "captureRay": 0.3,                      // Чувствительность рентген захвата, рекомендуемый диапазон от 0.02 до 0.5
    "nextCaptureRay": 0.05,                 // Чувствительность рентген захвата для повторной цели, если captureNext включен

// Настройки смещения и фиксированных точек (НЛД, корпус, башня)
    "AimPoint": 0.0,                        // Смещение прицела относительно центра цели, +- в метрах 
    "AimPointSPG": 0.0,                     // Смещение прицела для САУ относительно центра цели, +- в метрах
    "pointScroll": 0.1,                     // Шаг изменения высоты точки захвата по скроллу, в метрах
    "fixPointScrollEnable": true,           // Включение 3-х фиксированных точек (НЛД, корпус, башня)
    "fixPointOffset": [0.20, 0.50, 0.40],   // Настройки смещений относительно высоты элементов (корпус, башня)
                                            // 1 - для НЛД, 2 - для корпуса, 3 - для башни
                                            // для НЛД (0 - мин.высота корпуса, 1 - полн.высота корпуса)
                                            // для корпуса (0 - мин.высота - ур.земли, 1 - полн.высота цели )
                                            // для башни (0 - мин.высота башни, 1 - полн.высота башни)

    "fixPointScrollDefault": 1,             // Элемент по умолчанию: 0 - НЛД, 1 - корпус, 2 - башня
    "fixPointTimer": 10.0,                  // Задержка включения АвтоБота, после выбора фиксированной точки в сек.
    "chassisDist": 150.0,                   // Расстояние до цели с которого по функц.клавише захватываются катки (гусеницы), в метрах
                                            // цель при этом должна быть в автозахвате

    "enableFixAutorotation": false,         // Фиксация корпуса, в автозахвате (для безбашенной техники - снайперский и стратегический режим)
    "timeOut": 10.0,                        // Время задержки слежения за целью после пропадания из засвета, в сек.

// Упреждающие коэффициенты
    "offset": 1.0,                  // Упреждающий коэффициент (с версии 2.0.006 - норм. примерно 1.0)

// Интерполированный предел по пингу
    "autoOffset": true,             // Автоподстройка offset в зависимости от пинга
    "bufPingSize": 20,              // Размер буфера данных о пинге, 10 = средний пинг за 1 сек.
    "pingInterpolate": {"0":0.66, "15":0.9, "50":0.95, "200":1.0, "999":1.1},   // зависимость множителя offset от пинга
                                                                // формат "20":0.9 (20 - пинг, 0.9 * offset - коэффициент упреждения)
// Интерполированный предел
    "offsetInterpolate": {"0":9.0, "50":4.2, "100":2.0, "200":1.6, "250":1.5, "300":1.5, "400":1.5, "550":1.5},   // зависимость множителя offset от расстояния
                                                                // формат "100":1.8 (100 - расстояние, 1.8 * offset - коэффициент упреждения)

// Настройки зависимостей упреждения
    "standartDist": 0.0,            // Расстояние меньше которого аим переключается на стандартное упреждение, кроме захвата точки, м
    "standartSpeed": [20, 40],      // Диапазон скоростей в пределах которых действует поправка standartDist, км/ч

    "selfDist": 60.0,               // Расстояние меньше которого аим переключается на стандартное упреждение, кроме захвата точки, м
    "selfSpeed": 40.0,              // Собственная скорость выше которой действует поправка selfDist, км/ч

    "fidgetSpeed": 30.0,            // Скорость цели после достижения которой считается, что цель в движении, в % от максимальной км/ч,
                                    // если 0 - отключено
                                    // До этой скорости действует коэффициент снижающий упреждение для компенсации движения на месте

// Замедление перемещения прицела при захвате цели для уменьшения разброса
                                    // Если зажата "funcKey", то замедление игнорируется
    "slowAim": true,                // Включение для аркадного и снайперского режимов
    "slowSpeed": 20,                // Скорость перемещения прицела
    "slowAccel": 40,                // Коэффициент ускорения прицела
    "slowDiv": 2.0,                 // Делитель для неподвижной цели (влияет на плавность наводки), <1 - отключено
    "slowDist": 200.0,              // Расстояние меньше которого замедление отключено

    "slowAimSPG": true,             // Включение для стратегических режима
    "slowSpeedSPG": 20,             // Скорость перемещения прицела
    "slowAccelSPG": 40,             // Коэффициент ускорения прицела

    "slowSpeedFlame": 20,           // Скорость перемещения прицела для огнемётов
    "slowAccelFlame": 40,           // Коэффициент ускорения прицела для огнемётов

// Настройки СКВО (Системы контроля за ведением огня) работает только при захваченной цели, блокировку можно снять удерживая функц.клавиши "funcKey"
                                    // Если зажата "funcKey", то СКВО игнорируется
    "enableShootSystem": true,      // Включить СКВО
    "countShootClick": 3,           // количество повторов нажатий на кнопку "выстрел" для игнорирования блокировки 
    "notShootAllies": true,         // Принудительный запрет стрельбы по союзным
    "notShootKills": true,          // Принудительный запрет стрельбы по уничтоженным танкам
                                    // Блокировка по уничтоженным танкам будет работать только при захвате цели
    "timePostKill": 2.0,            // Время задержки срабатывания клавиши "выстрел" после уничтожения цели, в сек.
    "countDestruct": 1,             // количество объектов разрешённых для прострела вручную

// Настройки АвтоБота (авто-выцеливание)
// -------------------------------------
    "autoBot": true,                // Включение бота
    "autoBotToSPG": true,           // Включение бота при игре на САУ
    "scanCycle":1,                  // Частота сканирования брони (увеличивает скорость обработки данных, но нагружает вычислительный аппарат)
                                    // Не рекомендуется > 3
    "angleReset": 1.5,              // Угол сброса точек при повороте корпуса или башни цели в град.
    "pointsLimits":100,             // Ограничение количества искомых точек
    "pointsLimitsSector": 30,       // Ограничение количества искомых точек для секторального захвата
    "autoBotDistanceMin": 1,        // Минимальное расстояние с которого работает бот в автоматическом режиме, в метрах
    "autoBotDistanceMax": 600,      // Максимальное расстояние до которого работает бот в автоматическом режиме, в метрах
    "autoBotTargetMaxSpeed": 40.0,  // Ограничение максимальной скорости цели для включения бота в автоматическом режиме, в км/ч
    "autoBotSelfMaxSpeed": 40.0,    // Ограничение максимальной собственной скорости для включения бота в автоматическом режиме, в км/ч

    "sectorSize": 0.25,             // Размер сектора, в метрах
    "countSector": 8,               // Допустимое количество смещений сектора относительно первоначальной фиксации
    "keepPointPriority": false,     // Разрешать приоритет точки в месте захвата цели
    "firstPointPriority": 0,        // Приоритет захвата первичной точки, 0 - не учитывать
    "keepLastPoint": false,         // Сохранять последнюю приоритетную точку до выбора ботом новой точк после повторного захвата цели
                                    // или когда пропавшая цель снова видна и захвачена (сохраняется 1 раз)
    "timeFindBestPos": 0.2,         // Время задержки очередной проверки ботом лучшей позиции для выстрела, в сек.
    "deltaRotatPoint": 0.5,         // Расстояние между текущей и новой точкой больше которого происходит принудительное перемещение на новую, в м.
    "countRotatPoint": 2,           // Разрешённое количество перемещений по точкам
    "countLastPoint": 10,           // Необходимая минимальная статистика точек для проверки последней точки на пригодность
    "minDiffPercent": 25,           // Минимальная разница между количеством точек в сравниваемых деталях для объединения в общий массив, в %
                                    // 0% - полное совпадение (одинаковое количество), 100% - максимальное различие
    "ricoshetAngle": 60.0,          // Угол рикошета к нормали, в градусах (>70 - рикошет, согласно игровой механики)
    "ricoshetAngle_HC": 78.0,       // Угол рикошета к нормали, в градусах для кумулятивных боеприпасов (>85 - рикошет, согласно игровой механики)
    "minPercent": 60,               // Минимальный процент пробития брони для включения точки в расчёт ботом, от 0% - 100%
    "piersingPercent": 85,          // Желаемое пробитие брони в процентах для выбора точки из расчётных, в качестве искомой, от 0% - 100%
    "fieldPower": 3,                // Количество выборок зон пробития 1-3 (рекомендуется 1)
    "needRange": true,              // Разрешить боту выбирать точки превышающие лимит пунктов rangePercent
    "rangePercent": 10,             // Количество пунктов превышения пробития выбранной точки для побуждения бота к выбору следующей точки, от 0% - 30%
    "botPostTimer": 10.0,           // Время задержки удержания точки выбранной ботом после его отключения, в сек.
    "needFuelTank": true,          // Приоритет выцеливания топливного бака, если скорость цели < 5 км/ч
    "fuelTankDist": 300.0,          // Расстояние до которого действует привязка к топливным бакам
    "__visualPoints": false,       // техническая опция - визуализация точек пробития (вызывает проседание fps)
    "__visualPointsSector": false, // техническая опция - визуализация точек пробития (вызывает проседание fps)
    "__visualData": false,         // техническая опция - визуализация данных для настройки упреждения:
                                    // V - скорость цели (размер буфера); S - расстояние до цели(расчётный коэффициент); V/sh - скорость собственного снаряда; "Standart" - активация стандартного захвата

// Настройки автовыстрела
// ----------------------
    "autoShooting": false,          // Включить автовыстрел
    "autoShoot_LT": false,          // Включить автовыстрел для лёгких танков в начале битвы по умолчанию
    "autoShootDistMax": 500,        // Максимальное расстояние для автовыстрела, в метрах

    "dirSynchro": 0.25,             // Угол синхронизации направлений места прицеливания и фактического положения орудия для автовыстрела в град.
                                    // чувствительность автовыстрела к перемещению орудия (рекомендуемые значения от 0.1 до 90 град.)
    "minCountForShot": 5,           // Количество необходимых расчётных точек выбранных АвтоБотом для автоматического выстрела

// Настройки дисперсии сведения для автовыстрела
    "shootDispersion": 0.2,         // Дисперсия сведения необходимая для автовыстрела (0.0 - сведение полное, 0.1 чуть больше)
                                    // Зависимость линейная, от заданного значения до 0 по достижению autoShootDistMax
    "closeShootDispersion": 50.0,   // Дисперсия сведения для близких расстояний необходимая для автовыстрела

// Настройки круга сведения
// ------------------------
    "showRealDispersion": true,    // Показывать круг разброса, вместо круга сведения
    "corrRealDispersion": 0.0,      // Регулировочный коэффициент, 0 - круг разброса, 1 - круг сведения
                                    // если круг кажется слишком маленьким, то можно откорректировать его размер
    "minRealDispersion": 15,        // Минимально разрешённый визуальный размер сведения, оригинальное значение 32

// Настройки управления камерой
// ----------------------------
// Управлениие камерой позволяет моду, или используя функциональную клавишу, корректировать положение камеры, а в некоторых моментах миинимизировать потерю сведения
    "managerCam": true,             // Разрешить управление камерой
    "scrollCenterCam": false,       // Разрешить центрирование камеры на цели при входе в снайперский режим по скролу при расстоянии > 100м и скорости менее 5 км/ч
   
// Настройки автокоррекции дальномера
// ----------------------------------
    "fixDistAuto": true,            // Разрешить автоматическую коррекцию дальномера
    "fixDistMin": 50.0,             // Минимальное расстояние до цели при котором срабатывает автокорркция
    "fixDistPostTime": 5.0,         // Время задержки отключения фиксации дальномера

// Настройки информационной панели
// -------------------------------
// Информатор состояния дальномера
    "showFixDist": true,                            // Показывать информатор
    "showFixName": true,                			// Показывать наименование техники
    "FixDist_xy": [0, 0.6],                         // Координаты смещения
    "FixDistAnchor": "CENTER",                      // Выравнивание (CENTER,LEFT,RIGHT)
    "FixDistFont": {                                // Настройки шрифта
            "face": "Arial",                        // имя шрифта
            "size": 18,                             // размер
            "bold": true,                           // утолщение
            "dropShadow": true,                     // тень
            "shadowAlpha": 128                      // альфа тени (0-255)
            },

// Информатор пробития (в прецеле)
    "showDigital": true,                            // Показывать информатор пробития
    "showDigitalForAllies": false,                  // Показывать информатор пробития применительно к союзникам
    "digital_format": 1,                            // Три варианта формата:
                                                    // 0 - запас пробития от среднего значения
                                                    // 1 - процент вероятности пробития 50% = среднему значению пробития
                                                    // 2 - совмещённый вариант

    "digital_xy": [0, -0.06],                       // Координаты смещения
    "digitalAnchor": "CENTER",                      // Выравнивание (CENTER,LEFT,RIGHT)
    "digitalFont": {                                // Настройки шрифта
            "face": "Arial",                        // имя шрифта
            "size":20,                             // размер
            "bold": true,                           // утолщение
            "dropShadow": true,                     // тень
            "shadowAlpha": 128                      // альфа тени (0-255)
            },

// Информатор бронепробития
    "showArmorInformer": true,                      // Показывать информатор бронепробития
    "armorInformer_xy": [0.1, 0.2],                 // Координаты смещения
    "armorInformerFont": {                          // Настройки шрифта
            "face": "Arial",                        // имя шрифта
            "size": 16,                             // размер
            "bold": true,                           // утолщение
            "dropShadow": true,                     // тень
            "shadowAlpha": 128                      // альфа тени (0-255)
            },

// Информатор сопровождения цели
    "showTargetInformer": true,                     // Показывать информатор
    "targetInformer_xy": [0, -0.15],                // Координаты смещения 
    "targetInfoStrEnable": true,                    // Показывать строки 
    "targetInformerFile": "infoArrow2_green.dds",   // Вариант целеуказателя (стрелка), готов
    "targetInformerFile2": "infoArrow2_red.dds",    // Вариант целеуказателя, не готов
    "targetInformerSize": 128,                      // Размер целеуказателя (128)
    "targetInfoDistFont": {                         // Настройки шрифта 1я строка
            "face": "Arial",                        // имя шрифта
            "size": 16,                             // размер
            "bold": true,                           // утолщение
            "dropShadow": true,                     // тень
            "shadowAlpha": 128                      // альфа тени (0-255)
            },
    "targetInfoFont": {                             // Настройки шрифта 2я строка
            "face": "Arial",                        // имя шрифта
            "size": 16,                             // размер
            "bold": true,                           // утолщение
            "dropShadow": true,                     // тень
            "shadowAlpha": 128                      // альфа тени (0-255)
            },
    "targetInfoColor": [250, 200, 0, 255],          // Цвет строк

// Информатор статуса цели
    "targetInformerAim_xy": [0, 0.6],               // Координаты смещения строк
    "targetInformerAimAnchor": "CENTER",            // Выравнивание (CENTER,LEFT,RIGHT)
    "targetInformerAimFont": {                      // Настройки шрифта
            "face": "Arial",                        // имя шрифта 1я строка
            "size": 18,                             // размер
            "bold": false,                          // утолщение
            "dropShadow": true,                     // тень
            "shadowAlpha": 128                      // альфа тени (0-255)
            },
    "targetInformerAimFont2": {                     // Настройки шрифта 2я строка
            "face": "Arial",                        // имя шрифта
            "size": 20,                             // размер
            "bold": false,                          // утолщение
            "dropShadow": true,                     // тень
            "shadowAlpha": 128                      // альфа тени (0-255)
            },

// Индикатор пробития (большая мишень в верхней половине экрана)
    "showScopeAim": false,                          // Показывать индикатор пробития захваченной цели
    "scopeFile": "scope_green.dds",                 // Вариант индикатора пробития, пробьёт
    "scopeFile2": "scope_red.dds",                  // Вариант индикатора пробития, не пробьёт
    "scopeSize": 256,                               // Размер индикатора (256)

// Быстрый маркер упреждения
    "showFastMarker": false,                        // Показывать быстрый маркер упреждения
